{
  "name": "e2e-solana",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "React + Vite, Tailwind, @solana/react-hooks",
  "keywords": [
    "kit",
    "react",
    "solana-kit",
    "tailwind",
    "typescript",
    "vite"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "ci": "npm run build && npm run lint",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:prepare": "chroma download-extensions --wallets metamask"
  },
  "dependencies": {
    "@solana/client": "^1.0.0-rc.2",
    "@solana/kit": "^7.0.0",
    "@solana/react-hooks": "^1.0.0-rc.3",
    "@tailwindcss/vite": "^4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@avalix/chroma": "workspace:*",
    "@eslint-react/eslint-plugin": "^5.14.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  }
}

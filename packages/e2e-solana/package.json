{
  "name": "e2e-solana",
  "scripts": {
    "build": "tsc -b && vite build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:prepare": "chroma download-extensions"
  },
  "description": "React + Vite, Tailwind, @solana/react-hooks",
  "keywords": [
    "kit",
    "react",
    "solana-kit",
    "tailwind",
    "typescript",
    "vite"
  ],
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@solana/client": "^1.0.0-rc.2",
    "@solana/kit": "^7.0.0",
    "@solana/react-hooks": "^1.0.0-rc.3",
    "@tailwindcss/vite": "^4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@avalix/chroma": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^5",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  }
}

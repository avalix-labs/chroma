{
  "name": "@avalix/chroma",
  "type": "module",
  "version": "1.1.0",
  "description": "End-to-end testing library for Polkadot, Ethereum, and Solana wallet interactions",
  "author": "Avalix Labs",
  "license": "MIT",
  "homepage": "https://chroma.avalix.dev/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avalix-labs/chroma.git",
    "directory": "packages/chroma"
  },
  "bugs": {
    "url": "https://github.com/avalix-labs/chroma/issues"
  },
  "keywords": [
    "polkadot",
    "wallet",
    "testing",
    "e2e",
    "playwright",
    "automation",
    "blockchain"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "chroma": "./scripts/cli.js"
  },
  "files": [
    "dist",
    "scripts/cli.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "download-extensions": "tsx scripts/download-extensions.ts",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@playwright/test": "^1.61.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.18"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@playwright/test": "^1.61.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.6.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
